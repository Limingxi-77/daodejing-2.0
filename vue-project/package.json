{
  "name": "daodejing-vue",
  "version": "1.0.0",
  "description": "道德经AI平台 - Vue 3版本",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "e2e": "playwright test tests/e2e/smoke.spec.ts",
    "e2e:headed": "playwright test tests/e2e/smoke.spec.ts --headed",
    "e2e:integration": "playwright test tests/e2e/integration.spec.ts",
    "e2e:stream": "playwright test tests/e2e/ai-stream.spec.ts",
    "e2e:council": "playwright test tests/e2e/council.spec.ts",
    "e2e:scenarios": "playwright test tests/e2e/scenario-cards.spec.ts",
    "e2e:enterprise": "playwright test tests/e2e/pricing-enterprise.spec.ts",
    "e2e:business-plan": "playwright test tests/e2e/business-plan.spec.ts",
    "e2e:install": "playwright install --with-deps chromium",
    "lighthouse": "lhci autorun --config=.lighthouserc.json",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "lint:check": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "@types/dompurify": "^3.0.5",
    "@types/three": "^0.182.0",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "daodejing-2.0-workspace": "file:..",
    "dompurify": "^3.4.5",
    "fuse.js": "^7.1.0",
    "marked": "^17.0.1",
    "mysql2": "^3.18.2",
    "pinia": "^2.1.0",
    "three": "^0.182.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-vue": "^4.5.0",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/tsconfig": "^0.4.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "~5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vue-tsc": "^1.8.0"
  }
}
