    "backend:seed:smoke": "npm --prefix backend run seed:smoke",
    "backend:test": "npm --prefix backend test",
    "backend:worker:tts": "npm --prefix backend run worker:tts",
    "frontend:dev": "npm --prefix vue-project run dev",
