# Express 前台业务后端配置
PORT=8000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# MySQL 主业务数据库
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=daodejing
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=daodejing_platform

# 前台用户 JWT
JWT_SECRET=change-me-user-jwt-secret
JWT_EXPIRES_IN=7d

# 后台管理员 JWT
ADMIN_JWT_SECRET=change-me-admin-jwt-secret
ADMIN_JWT_EXPIRES_IN=8h

# hAdmin 调用 Express 内部管理 API 的共享令牌
HADMIN_INTERNAL_TOKEN=change-me-hadmin-internal-token

# 安全与可观测性
RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120
AI_RATE_LIMIT_MAX=30
TTS_RATE_LIMIT_MAX=20
LOGIN_RATE_LIMIT_MAX=10
LOGIN_FAILURE_LIMIT=5
LOGIN_LOCK_MS=900000
ENABLE_ACCESS_LOGS=true
AI_DEFAULT_COST_PER_1K_TOKENS=0
SECURITY_STATE_DRIVER=memory
ALERT_MIN_LEVEL=error
ALERT_WEBHOOK_URL=
TTS_WORKER_INTERVAL_MS=5000
TTS_WORKER_BATCH_SIZE=3

# 可选：首次启动自动创建超级管理员
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me-admin-password

# 可选：前台 AI 代理供应商密钥（若未配置则返回演示模式响应）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-v4-flash
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=google/gemini-2.0-flash-lite-preview-02-05:free
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-3.5-turbo

# 可选：TTS 后端代理密钥，未配置时前端使用浏览器内置语音合成
DASHSCOPE_API_KEY=
DASHSCOPE_TTS_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
COSYVOICE_MODEL=cosyvoice-v1

# Smoke / 集成验收
SMOKE_BASE_URL=http://127.0.0.1:8000
SMOKE_USER_EMAIL=smoke-user@example.com
SMOKE_USER_USERNAME=smoke_user
SMOKE_USER_PASSWORD=SmokePass123!
SMOKE_ADMIN_USERNAME=admin
SMOKE_ADMIN_PASSWORD=change-me-admin-password
SMOKE_HADMIN_TOKEN=change-me-hadmin-internal-token
SMOKE_RESOURCE_KEYWORD=集成验收资源
SMOKE_RESOURCE_TITLE=集成验收资源 - 道德经
SMOKE_RESOURCE_CATEGORY_SLUG=learning
